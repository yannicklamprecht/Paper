diff --git a/src/main/java/org/bukkit/packet/PacketOptions.java b/src/main/java/org/bukkit/packet/PacketOptions.java
new file mode 100644
index 0000000000000000000000000000000000000000..01b515595b4a980d74d62fb334dc17b4ef872dd5
--- /dev/null
+++ b/src/main/java/org/bukkit/packet/PacketOptions.java
@@ -0,0 +1,49 @@
+package org.bukkit.packet;
+
+public class PacketOptions {
+
+    public enum TeamMode {
+        CREATE_TEAM(0),
+        REMOVE_TEAM(1),
+        UPDATE_TEAM_INFO(2),
+        ADD_PLAYERS_TO_TEAM(3),
+        REMOVE_PLAYERS_FROM_TEAM(4);
+
+        private final int mode;
+
+        TeamMode(int mode) {
+            this.mode = mode;
+        }
+
+        public int getMode() {
+            return mode;
+        }
+    }
+
+    public enum ProfileAction {
+        ADD_PLAYER,
+        UPDATE_GAME_MODE,
+        UPDATE_LATENCY,
+        UPDATE_DISPLAY_NAME,
+        REMOVE_PLAYER;
+    }
+
+    public enum Animation {
+        SWING_MAIN_ARM(0),
+        TAKE_DAMAGE(1),
+        LEAVE_BED(2),
+        SWING_OFFHAND(3),
+        CRITICAL_EFFECT(4),
+        MAGIC_CRITICAL_EFFECT(5);
+
+        private final int action;
+
+        Animation(int action) {
+            this.action = action;
+        }
+
+        public int getAction() {
+            return action;
+        }
+    }
+}
diff --git a/src/main/java/org/bukkit/packet/PacketPipeline.java b/src/main/java/org/bukkit/packet/PacketPipeline.java
