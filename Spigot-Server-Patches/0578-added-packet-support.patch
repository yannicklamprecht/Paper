+package org.bukkit.craftbukkit.packet.steps;
+
+import com.destroystokyo.paper.profile.CraftPlayerProfile;
+import com.destroystokyo.paper.profile.PlayerProfile;
+import com.mojang.authlib.GameProfile;
+import net.minecraft.server.EnumGamemode;
+import net.minecraft.server.PacketPlayOutPlayerInfo;
+import org.bukkit.craftbukkit.packet.AbstractPacketStep;
+import org.bukkit.entity.Player;
+import org.bukkit.packet.PacketOptions;
+
+import java.util.Collection;
+
+public class ProfilePacketStep extends AbstractPacketStep {
+
+    private final PacketPlayOutPlayerInfo clientboundPlayerInfoPacket;
+
+    public ProfilePacketStep(PlayerProfile playerProfile, PacketOptions.ProfileAction profileAction) {
+        GameProfile gameProfile = ((CraftPlayerProfile) playerProfile).getGameProfile();
+        this.clientboundPlayerInfoPacket = new PacketPlayOutPlayerInfo();
+        PacketPlayOutPlayerInfo.PlayerInfoData playerUpdate = new PacketPlayOutPlayerInfo.PlayerInfoData(gameProfile, 0, EnumGamemode.NOT_SET, null);
+        this.clientboundPlayerInfoPacket.b.add(playerUpdate);
+        this.clientboundPlayerInfoPacket.a = from(profileAction);
+    }
+
+    @Override
+    protected void executeStep(Collection<? extends Player> players) {
+        for (Player player : players) {
+            sendPacket(player, clientboundPlayerInfoPacket);
+        }
+    }
+
+    public PacketPlayOutPlayerInfo.EnumPlayerInfoAction from(PacketOptions.ProfileAction action) {
+        switch (action) {
+            case ADD_PLAYER:
+                return PacketPlayOutPlayerInfo.EnumPlayerInfoAction.ADD_PLAYER;
+            case REMOVE_PLAYER:
+                return PacketPlayOutPlayerInfo.EnumPlayerInfoAction.REMOVE_PLAYER;
+            case UPDATE_LATENCY:
+                return PacketPlayOutPlayerInfo.EnumPlayerInfoAction.UPDATE_LATENCY;
+            case UPDATE_GAME_MODE:
+                return PacketPlayOutPlayerInfo.EnumPlayerInfoAction.UPDATE_GAME_MODE;
+            case UPDATE_DISPLAY_NAME:
+                return PacketPlayOutPlayerInfo.EnumPlayerInfoAction.UPDATE_DISPLAY_NAME;
+        }
+        return PacketPlayOutPlayerInfo.EnumPlayerInfoAction.REMOVE_PLAYER;
+    }
+
+}
