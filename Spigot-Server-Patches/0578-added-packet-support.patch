+        initial.setNext(new TeleportEntityPacketStep(entityId, location, onGround));
+        return this;
+    }
+
+    @Override
+    public PacketStepBuilder sendBlockChange(Location location, BlockData blockData) {
+        initial.setNext(new AbstractPacketStep() {
